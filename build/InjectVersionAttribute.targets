<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="GenerateAssemblyInfoFile"
          Inputs="$(MSBuildThisFileFullPath);$(MSBuildProjectFullPath)"
          Outputs="$(GeneratedAssemblyInfoFile)"
          BeforeTargets="BeforeCompile">

    <Error Condition="'$(ProductVersion)'==''" Text="ProductVersion is not defined" />

    <PropertyGroup>
      <_InformationalVersion>$(ProductVersionExtended)</_InformationalVersion>
      <_InformationalVersion Condition="'$(_InformationalVersion)'==''">$(ProductVersion)</_InformationalVersion>
    </PropertyGroup>

    <ItemGroup>
      <AssemblyAttribute Include="System.Reflection.AssemblyVersionAttribute">
        <_Parameter1>$(ProductVersion)</_Parameter1>
      </AssemblyAttribute>
      <AssemblyAttribute Include="System.Reflection.AssemblyFileVersionAttribute">
        <_Parameter1>$(ProductVersion)</_Parameter1>
      </AssemblyAttribute>
      <AssemblyAttribute Include="System.Reflection.AssemblyInformationalVersionAttribute">
        <_Parameter1>$(_InformationalVersion)</_Parameter1>
      </AssemblyAttribute>
    </ItemGroup>

    <WriteCodeFragment AssemblyAttributes="@(AssemblyAttribute)" Language="C#"
      OutputFile="$(GeneratedAssemblyInfoFile)">
      <Output TaskParameter="OutputFile" ItemName="Compile" />
      <Output TaskParameter="OutputFile" ItemName="FileWrites" />
    </WriteCodeFragment>

  </Target>
</Project>